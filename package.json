{
  "name": "ewalletbunker",
  "version": "1.0.0",
  "main": "App.js",
  "private": true,
  "scripts": {
    "start": "expo start --tunnel --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "test": "jest --watchAll=false --forceExit"
  },
  "dependencies": {
    "expo": "^54.0.0",
    "expo-status-bar": "^2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.9"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@faker-js/faker": "^8.4.1",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "^13.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.0",
    "react-test-renderer": "18.3.1"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@faker-js)/)"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/*.test.js"
    ],
    "moduleFileExtensions": ["js", "jsx", "json", "ts", "tsx"],
    "testEnvironment": "node"
  }
}